# Discord bot token (Developer Portal → your app → Bot → Reset Token).
DISCORD_TOKEN=your-bot-token-here

# Shared secret. The dashboard must send this as the x-api-key header.
API_KEY=change-me-to-a-long-random-string

# HTTP port the checker API listens on.
PORT=8787

# CORS: the origin of your dashboard (GitHub Pages URL), or * for any.
ALLOW_ORIGIN=*

# Comma-separated Discord user IDs allowed to run the admin slash commands
# (/server, /verlassen). Leave empty to allow anyone (not recommended).
OWNER_IDS=

# Where the hosted ZeroTrace.exe lives. The /scanner?pin= endpoint fetches it
# and wraps it with a zerotrace.pin file into a one-click ZIP download.
SCANNER_EXE_URL=https://leopoldhartung7-debug.github.io/ZeroTrace/ZeroTrace.exe
