# Discord bot token (Developer Portal → your app → Bot → Reset Token).
DISCORD_TOKEN=your-bot-token-here

# Shared secret. The dashboard must send this as the x-api-key header.
API_KEY=change-me-to-a-long-random-string

# HTTP port the checker API listens on.
PORT=8787

# CORS: the origin of your dashboard (GitHub Pages URL), or * for any.
ALLOW_ORIGIN=*
