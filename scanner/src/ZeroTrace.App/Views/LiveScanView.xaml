<UserControl x:Class="ZeroTrace.App.Views.LiveScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header + controls -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Live-Scan" Style="{StaticResource H1}" />
                <TextBlock Text="Zeigt nur, was gerade geprueft wird. Ergebnisse danach unter Funde." Style="{StaticResource Muted}" Margin="0,2,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Scan starten" Style="{StaticResource PrimaryButton}"
                        Command="{Binding StartScanCommand}" Margin="0,0,8,0" />
                <Button Content="Abbrechen" Style="{StaticResource GhostButton}"
                        Command="{Binding CancelScanCommand}" />
            </StackPanel>
        </Grid>

        <!-- Progress -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,18,0,12">
            <StackPanel>
                <Grid>
                    <TextBlock Text="{Binding Phase}" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}">
                        <Path Data="M 0,5 L 4,9 L 11,1" Stroke="#22CC66" StrokeThickness="2.4"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Scan abgeschlossen" Foreground="#22CC66" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding LastSendStatus}" Foreground="#22CC66" FontWeight="SemiBold"
                                   Margin="8,0,0,0"
                                   Visibility="{Binding LastSendStatus, Converter={StaticResource NullToVis}}" />
                    </StackPanel>
                    <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource MutedBrush}"
                               Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                        <Run Text="{Binding Progress, StringFormat={}{0:0}, Mode=OneWay}" />
                        <Run Text="%" />
                    </TextBlock>
                </Grid>
                <ProgressBar Value="{Binding Progress, Mode=OneWay}" Maximum="100" Margin="0,10,0,0" />
            </StackPanel>
        </Border>

        <!-- Minimal scan view: only what is being checked right now. -->
        <Border Grid.Row="2" Grid.RowSpan="2" Style="{StaticResource Card}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="SCANNE GERADE" Style="{StaticResource Muted}"
                           HorizontalAlignment="Center" Margin="0,0,0,10" />
                <TextBlock Text="{Binding CurrentModule, Mode=OneWay}" TextAlignment="Center"
                           TextWrapping="Wrap" FontSize="18" FontWeight="SemiBold" MaxWidth="640" />
                <TextBlock Text="{Binding CurrentItem, Mode=OneWay}" TextAlignment="Center"
                           TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center" MaxWidth="640" Margin="0,6,0,0"
                           Visibility="{Binding CurrentItem, Converter={StaticResource NullToVis}}" />
                <TextBlock Text="Die Ergebnisse werden nach dem Scan unter Funde angezeigt."
                           Style="{StaticResource Muted}" HorizontalAlignment="Center"
                           TextAlignment="Center" TextWrapping="Wrap" MaxWidth="520" Margin="0,20,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
