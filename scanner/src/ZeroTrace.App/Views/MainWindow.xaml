<Window x:Class="ZeroTrace.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ZeroTrace.App.Views"
        Title="ZeroTrace"
        Width="800" Height="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        MouseLeftButtonDown="Window_Drag">

    <Window.Resources>
        <!-- ===== Game-select tile ===== -->
        <Style x:Key="GameBtn" TargetType="Button">
            <Setter Property="Width" Value="120" />
            <Setter Property="Height" Value="78" />
            <Setter Property="Margin" Value="5,0" />
            <Setter Property="Foreground" Value="#C8D4DC" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="14" BorderThickness="1"
                                BorderBrush="#2E8296A0" Background="#61191D24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource ScannerAccentBrush}" />
                                <Setter TargetName="b" Property="Background" Value="#8C283440" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Accent button ===== -->
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#0E1418" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="6" Background="{DynamicResource ScannerAccentBrush}" Padding="22,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Background" Value="#2A3038" />
                                <Setter Property="Foreground" Value="#3A4450" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Ghost button ===== -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#C2CCD4" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="6" Background="#2A313A" Padding="22,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#343C46" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Close (x) ===== -->
        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#5A6772" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Width="24" Height="24" CornerRadius="6" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#22313A" />
                                <Setter Property="Foreground" Value="#C8D4DC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== PIN cell ===== -->
        <Style x:Key="PinCell" TargetType="TextBox">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="33" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="MaxLength" Value="1" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#C8D2DA" />
            <Setter Property="CaretBrush" Value="{DynamicResource ScannerAccentBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#3A4350" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ===== Card ===== -->
    <Border Margin="16" CornerRadius="14" Background="{DynamicResource ScannerPanelBrush}"
            BorderBrush="#264EBCD2" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.55" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- top accent line -->
            <Border Grid.Row="0" Height="2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#004EBCD2" Offset="0" />
                        <GradientStop Color="{DynamicResource ScannerAccentColor}" Offset="0.5" />
                        <GradientStop Color="#004EBCD2" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid Grid.Row="1" ClipToBounds="True">
                <!-- animated particle background (behind everything) -->
                <views:ParticleField />

                <!-- close button -->
                <Button Content="✕" Style="{StaticResource CloseBtn}" Click="Close_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,10,0"
                        Panel.ZIndex="2" />

                <!-- two columns: left branding, right flow -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="290" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: branding -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Image Source="pack://application:,,,/Resources/zt-logo.png"
                                   Height="40" Width="52" Margin="0,0,12,0"
                                   Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                            <TextBlock VerticalAlignment="Center" FontSize="26" FontWeight="Bold">
                                <Run Text="Zero" Foreground="{DynamicResource ScannerAccentBrush}" /><Run Text="Trace" Foreground="#8A9AAA" />
                            </TextBlock>
                        </StackPanel>
                        <TextBlock x:Name="SubText" Text="Host-Scanner" Foreground="#5A6772"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,10,0,0" />
                        <TextBlock Text="Lokale Cheat- &amp; Manipulations-Analyse"
                                   Foreground="#46505C" FontSize="11" HorizontalAlignment="Center"
                                   TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0" />
                        <TextBlock Text="{DynamicResource ScannerVersion}" Foreground="#3A444E" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,10,0,0" />
                    </StackPanel>

                    <!-- divider -->
                    <Border Grid.Column="0" Width="1" Background="#242A33"
                            HorizontalAlignment="Right" Margin="0,40" />

                    <!-- RIGHT: step flow -->
                    <Grid Grid.Column="1" Margin="34,16">
                        <!-- INTRO: animation -->
                        <Grid x:Name="IntroView" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <MediaElement x:Name="IntroVideo"
                                          LoadedBehavior="Manual"
                                          UnloadedBehavior="Stop"
                                          Stretch="UniformToFill"
                                          MediaEnded="IntroVideo_MediaEnded"
                                          MediaFailed="IntroVideo_MediaFailed" />
                        </Grid>

                        <!-- 0) GAME SELECT -->
                        <StackPanel x:Name="GameView" Visibility="Collapsed" VerticalAlignment="Center">
                            <TextBlock Text="Spiel auswählen" Foreground="#8A9AAA" FontSize="13"
                                       FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,14" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Style="{StaticResource GameBtn}" Tag="FiveM"  Click="Game_Click" Content="FiveM" />
                                <Button Style="{StaticResource GameBtn}" Tag="alt:V"  Click="Game_Click" Content="alt:V" />
                                <Button Style="{StaticResource GameBtn}" Tag="RageMP" Click="Game_Click" Content="RageMP" />
                            </StackPanel>
                            <!-- Profile selector -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                                <TextBlock Text="Scan-Profil:" Foreground="#5A6772" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ComboBox x:Name="ProfileComboBox" Width="120" FontSize="11"
                                          Background="#1A2028" Foreground="#C8D4DC"
                                          BorderBrush="#2A3038" BorderThickness="1"
                                          SelectedIndex="1"
                                          SelectionChanged="ProfileComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Quick" Tag="Quick" />
                                    <ComboBoxItem Content="Standard" Tag="Standard" IsSelected="True" />
                                    <ComboBoxItem Content="Deep" Tag="Deep" />
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>

                        <!-- 1) PIN -->
                        <StackPanel x:Name="PinView" Visibility="Collapsed" VerticalAlignment="Center">
                            <Border BorderBrush="#2A3038" BorderThickness="1" CornerRadius="11"
                                    Padding="14,12" HorizontalAlignment="Center" Background="#03FFFFFF">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource ScannerTextPin}" Foreground="#8A9AAA"
                                               FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,10" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBox x:Name="P0" Style="{StaticResource PinCell}" TextChanged="Pin_Changed" PreviewKeyDown="Pin_KeyDown" GotFocus="Pin_GotFocus" />
                                        <TextBox x:Name="P1" Style="{StaticResource PinCell}" TextChanged="Pin_Changed" PreviewKeyDown="Pin_KeyDown" GotFocus="Pin_GotFocus" />
                                        <TextBox x:Name="P2" Style="{StaticResource PinCell}" TextChanged="Pin_Changed" PreviewKeyDown="Pin_KeyDown" GotFocus="Pin_GotFocus" />
                                        <TextBox x:Name="P3" Style="{StaticResource PinCell}" TextChanged="Pin_Changed" PreviewKeyDown="Pin_KeyDown" GotFocus="Pin_GotFocus" />
                                        <TextBox x:Name="P4" Style="{StaticResource PinCell}" TextChanged="Pin_Changed" PreviewKeyDown="Pin_KeyDown" GotFocus="Pin_GotFocus" />
                                        <TextBox x:Name="P5" Style="{StaticResource PinCell}" TextChanged="Pin_Changed" PreviewKeyDown="Pin_KeyDown" GotFocus="Pin_GotFocus" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <TextBlock x:Name="PinErr" Foreground="#EF5350" FontSize="11"
                                       HorizontalAlignment="Center" Margin="0,8,0,0" />
                            <Button x:Name="PinNext" Content="Weiter" Style="{StaticResource AccentBtn}"
                                    Click="PinNext_Click" HorizontalAlignment="Center" Margin="0,8,0,0" IsEnabled="False" />
                        </StackPanel>

                        <!-- 2) CONSENT -->
                        <StackPanel x:Name="ConsentView" Visibility="Collapsed" VerticalAlignment="Center">
                            <TextBlock Text="Lizenzvereinbarung &amp; Datenschutz" Foreground="#E6EDF2"
                                       FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="Bitte lies die Bedingungen, bevor du fortfährst." Foreground="#5A6772"
                                       FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,8" />
                            <Border Background="#191D24" BorderBrush="#2A3038" BorderThickness="1" CornerRadius="7" Height="150">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="13,11">
                                    <StackPanel>
                                        <TextBlock Text="ENDBENUTZER-LIZENZ- UND DATENSCHUTZVEREINBARUNG"
                                                   Foreground="#C8D4DC" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap" />
                                        <TextBlock TextWrapping="Wrap" Foreground="#9AAAB4" FontSize="11" LineHeight="17"
                                                   Text="ZeroTrace ist ein lokales Analysewerkzeug, das diesen PC auf Hinweise für Cheats und Manipulationen untersucht. Mit „Akzeptieren“ stimmst du der nachfolgend beschriebenen Prüfung zu." />
                                        <TextBlock Text="1. Was geprüft wird" Foreground="{DynamicResource ScannerAccentBrush}" FontWeight="SemiBold" FontSize="11" Margin="0,12,0,3" />
                                        <TextBlock TextWrapping="Wrap" Foreground="#9AAAB4" FontSize="11" LineHeight="17"
                                                   Text="Laufende Prozesse samt geladener Module, Autostart, ausgewählte Registry-Schlüssel, die Verzeichnisse von FiveM, RageMP und alt:V, der Downloads-Ordner sowie Dateien auf festen Laufwerken. Zusätzlich der lokale Browser-Verlauf auf bekannte Cheat-/Reseller-Domains und die lokal gecachten Discord-Server-Mitgliedschaften, um Cheat- und Reseller-Discords zu erkennen (nur Server-Namen und -IDs)." />
                                        <TextBlock Text="2. Was mit den Ergebnissen geschieht" Foreground="{DynamicResource ScannerAccentBrush}" FontWeight="SemiBold" FontSize="11" Margin="0,12,0,3" />
                                        <TextBlock TextWrapping="Wrap" Foreground="#9AAAB4" FontSize="11" LineHeight="17"
                                                   Text="Die Ergebnisse werden dem eingegebenen PIN zugeordnet und an die hinterlegte Adresse des Veranstalters gesendet. Danach erscheint der Hinweis „Scan abgeschlossen“." />
                                        <TextBlock Text="3. Was ZeroTrace nicht tut" Foreground="{DynamicResource ScannerAccentBrush}" FontWeight="SemiBold" FontSize="11" Margin="0,12,0,3" />
                                        <TextBlock TextWrapping="Wrap" Foreground="#9AAAB4" FontSize="11" LineHeight="17"
                                                   Text="Keine Änderungen an Prozessen, Dateien oder der Registry – ZeroTrace liest ausschließlich. Es werden keine Discord-Tokens, Nachrichten oder DMs ausgelesen, ausschließlich die Namen und IDs der Discord-Server, in denen der Account Mitglied ist." />
                                        <TextBlock Text="4. Hinweis" Foreground="{DynamicResource ScannerAccentBrush}" FontWeight="SemiBold" FontSize="11" Margin="0,12,0,3" />
                                        <TextBlock TextWrapping="Wrap" Foreground="#9AAAB4" FontSize="11" LineHeight="17"
                                                   Text="Funde sind Indizien, kein Beweis für Cheating. Fehlalarme sind möglich." />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                            <TextBlock x:Name="DeclineNote" Foreground="#F59E0B" FontSize="11"
                                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                <Button Content="✔  Akzeptieren" Style="{StaticResource AccentBtn}" Click="Accept_Click" Margin="0,0,10,0" />
                                <Button Content="✖  Ablehnen" Style="{StaticResource GhostBtn}" Click="Decline_Click" />
                            </StackPanel>
                        </StackPanel>

                        <!-- 3) SCAN -->
                        <StackPanel x:Name="ScanView" Visibility="Collapsed" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                                <TextBlock x:Name="PctText" Text="0%" Foreground="#C8D4DC" FontSize="13" FontWeight="Bold" Width="42" />
                                <TextBlock Text="LÄUFT" Foreground="#5A6772" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                            <Border Height="16" Background="#191D24" CornerRadius="3" ClipToBounds="True">
                                <Border x:Name="BarFill" Background="{DynamicResource ScannerAccentBrush}" CornerRadius="3"
                                        HorizontalAlignment="Stretch" RenderTransformOrigin="0,0">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="BarScale" ScaleX="0" />
                                    </Border.RenderTransform>
                                </Border>
                            </Border>
                            <TextBlock Text="{DynamicResource ScannerTextScanning}" Foreground="#5A6772" FontSize="11" Margin="0,18,0,0" />
                            <TextBlock x:Name="NowPath" Text="…" Foreground="#C8D4DC" FontSize="15"
                                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,6,0,0" />
                        </StackPanel>

                        <!-- 4) RESULT -->
                        <StackPanel x:Name="ResultView" Visibility="Collapsed" VerticalAlignment="Center">
                            <StackPanel x:Name="ResultContent" Opacity="0" RenderTransformOrigin="0.5,0.5">
                                <StackPanel.RenderTransform>
                                    <ScaleTransform x:Name="ResultScale" ScaleX="0.7" ScaleY="0.7" />
                                </StackPanel.RenderTransform>
                                <Viewbox Width="92" Height="92" HorizontalAlignment="Center">
                                    <Canvas Width="140" Height="140">
                                        <Ellipse Width="110" Height="110" Canvas.Left="15" Canvas.Top="15"
                                                 Stroke="#22CC66" StrokeThickness="1.5" Opacity="0.15" />
                                        <Path x:Name="CheckPath" Stroke="#22CC66" StrokeThickness="6"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Data="M 38,70 L 58,90 L 102,48"
                                              StrokeDashArray="16 16" StrokeDashOffset="16" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{DynamicResource ScannerTextFinished}" Foreground="#C8D2DA" FontSize="19"
                                           FontWeight="Bold" HorizontalAlignment="Center" Margin="0,14,0,0" />
                                <TextBlock x:Name="CountText" Foreground="#5A6772" FontSize="11"
                                           HorizontalAlignment="Center" Margin="0,8,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
