<Window x:Class="ZeroTrace.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ZeroTrace.App.ViewModels"
        xmlns:views="clr-namespace:ZeroTrace.App.Views"
        Title="ZeroTrace" Height="760" Width="1180"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" SizeToContent="Manual"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LiveScanViewModel}">
            <views:LiveScanView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FindingsViewModel}">
            <views:FindingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <views:ReportsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="232" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== Navigation rail ===== -->
        <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,12">
                    <TextBlock Text="ZeroTrace" Style="{StaticResource H1}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="16,12,16,16">
                    <Border Background="{StaticResource PanelAltBrush}" CornerRadius="8" Padding="10">
                        <TextBlock Text="{Binding ElevationText}" TextWrapping="Wrap"
                                   Style="{StaticResource Muted}" />
                    </Border>
                    <Button Content="ZeroTrace entfernen" Style="{StaticResource GhostButton}"
                            Command="{Binding RemoveCommand}" Margin="0,10,0,0"
                            HorizontalAlignment="Stretch" />
                    <TextBlock Text="v1.0 - lokal; senden nur nach Bestaetigung"
                               Style="{StaticResource Muted}" Margin="2,8,0,0" />
                </StackPanel>

                <StackPanel Margin="0,8,0,0">
                    <RadioButton Content="Dashboard" Style="{StaticResource NavButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Dashboard"
                                 IsChecked="{Binding CurrentPage, Converter={StaticResource EqualsToBool},
                                             ConverterParameter=Dashboard, Mode=OneWay}" />
                    <RadioButton Content="Live-Scan" Style="{StaticResource NavButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="LiveScan"
                                 IsChecked="{Binding CurrentPage, Converter={StaticResource EqualsToBool},
                                             ConverterParameter=LiveScan, Mode=OneWay}" />
                    <RadioButton Content="Funde" Style="{StaticResource NavButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Findings"
                                 IsChecked="{Binding CurrentPage, Converter={StaticResource EqualsToBool},
                                             ConverterParameter=Findings, Mode=OneWay}" />
                    <RadioButton Content="Berichte" Style="{StaticResource NavButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Reports"
                                 IsChecked="{Binding CurrentPage, Converter={StaticResource EqualsToBool},
                                             ConverterParameter=Reports, Mode=OneWay}" />
                    <RadioButton Content="Einstellungen" Style="{StaticResource NavButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Settings"
                                 IsChecked="{Binding CurrentPage, Converter={StaticResource EqualsToBool},
                                             ConverterParameter=Settings, Mode=OneWay}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== Content host ===== -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" Margin="0" />

        <!-- ===== Completion overlay =====
             After a scan finishes, the whole window shows ONLY a green check and
             "Scan abgeschlossen"; the program then closes itself after 5 seconds. -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Background="{StaticResource BgBrush}"
                Visibility="{Binding LiveScan.IsCompleted, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Path Data="M 0,18 L 14,32 L 40,4" Stroke="#22CC66" StrokeThickness="7"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Stretch="Uniform" Width="132" Height="110" HorizontalAlignment="Center" />
                <TextBlock Text="Scan abgeschlossen" Foreground="#22CC66"
                           FontSize="30" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,30,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
