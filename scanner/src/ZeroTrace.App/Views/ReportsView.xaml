<UserControl x:Class="ZeroTrace.App.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Berichte" Style="{StaticResource H1}" />
                <TextBlock Text="Fruehere Scans ansehen und exportieren" Style="{StaticResource Muted}" Margin="0,2,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="Aktualisieren" Style="{StaticResource GhostButton}"
                    Command="{Binding RefreshCommand}" VerticalAlignment="Center" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Scan list -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0" Margin="0,0,12,0">
                <ListBox ItemsSource="{Binding Scans}" SelectedItem="{Binding SelectedScan}"
                         HorizontalContentAlignment="Stretch" Padding="6">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource PanelAltBrush}" CornerRadius="8"
                                    Padding="12,10" Margin="2,3">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold">
                                        <Run Text="Scan #" /><Run Text="{Binding Id, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource Muted}"
                                               Text="{Binding StartedUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" />
                                    <TextBlock Style="{StaticResource Muted}">
                                        <Run Text="{Binding Result, Mode=OneWay}" />
                                        <Run Text=" - " />
                                        <Run Text="{Binding FilesScanned, Mode=OneWay}" /><Run Text=" Dateien" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Detail -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Visibility="{Binding Detail, Converter={StaticResource NullToVis}}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Style="{StaticResource H2}">
                                    <Run Text="Scan #" /><Run Text="{Binding Detail.Id, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource Muted}"
                                           Text="{Binding Detail.MachineName}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Button Content="HTML" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ExportHtmlCommand}" Margin="0,0,8,0" />
                                <Button Content="JSON" Style="{StaticResource GhostButton}"
                                        Command="{Binding ExportJsonCommand}" Margin="0,0,8,0" />
                                <Button Content="TXT" Style="{StaticResource GhostButton}"
                                        Command="{Binding ExportTextCommand}" Margin="0,0,8,0" />
                                <Button Content="Loeschen" Style="{StaticResource GhostButton}"
                                        Command="{Binding DeleteCommand}" />
                            </StackPanel>
                        </Grid>

                        <UniformGrid Columns="4" Margin="0,16,0,16">
                            <StackPanel>
                                <TextBlock Text="{Binding Detail.CriticalCount}" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource CriticalBrush}" />
                                <TextBlock Text="Critical" Style="{StaticResource Muted}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding Detail.HighCount}" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource HighBrush}" />
                                <TextBlock Text="High" Style="{StaticResource Muted}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding Detail.MediumCount}" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource MediumBrush}" />
                                <TextBlock Text="Medium" Style="{StaticResource Muted}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding Detail.LowCount}" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource LowBrush}" />
                                <TextBlock Text="Low" Style="{StaticResource Muted}" />
                            </StackPanel>
                        </UniformGrid>

                        <DataGrid ItemsSource="{Binding Detail.Findings}" MaxHeight="420">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Risiko" Width="92">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource RiskPill}"
                                                    Background="{Binding Risk, Converter={StaticResource RiskToBrush}}">
                                                <TextBlock Text="{Binding Risk}" Foreground="#06121A"
                                                           FontWeight="Bold" FontSize="11" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Titel" Binding="{Binding Title}" Width="*" />
                                <DataGridTextColumn Header="Modul" Binding="{Binding Module}" Width="100" />
                                <DataGridTextColumn Header="Ort" Binding="{Binding Location}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Transparent, consent-based sending -->
                        <Border Background="{StaticResource PanelAltBrush}" CornerRadius="9"
                                Padding="14" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Ergebnisse senden" Style="{StaticResource H2}" Margin="0,0,0,4" />
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource Muted}"
                                           Text="Der Bericht wird nur nach ausdruecklicher Bestaetigung an die unten angegebene Adresse gesendet. Nichts wird automatisch oder im Hintergrund uebertragen. Die genaue Nutzlast ist unten sichtbar." />

                                <TextBlock Text="Ziel-Adresse (Webhook / Website)" Style="{StaticResource Muted}" Margin="0,12,0,4" />
                                <TextBox Text="{Binding WebhookUrl, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="Diese Daten werden uebertragen (Vorschau)" Style="{StaticResource Muted}" Margin="0,12,0,4" />
                                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1" CornerRadius="8" MaxHeight="180">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                                        <TextBox Text="{Binding PayloadPreview, Mode=OneWay}" IsReadOnly="True"
                                                 BorderThickness="0" Background="Transparent"
                                                 FontFamily="Consolas, monospace" FontSize="11"
                                                 TextWrapping="Wrap" Foreground="{StaticResource AccentBrush}" />
                                    </ScrollViewer>
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="Jetzt senden" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding SendCommand}" />
                                    <TextBlock Text="{Binding SendStatus}" VerticalAlignment="Center"
                                               Margin="12,0,0,0" Style="{StaticResource Muted}" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
