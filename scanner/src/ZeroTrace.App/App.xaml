<Application x:Class="ZeroTrace.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ZeroTrace.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:RiskLevelToBrushConverter x:Key="RiskToBrush" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:NullToVisibilityConverter x:Key="NullToVis" />
            <conv:BytesToHumanConverter x:Key="BytesToHuman" />
            <conv:EqualsToBoolConverter x:Key="EqualsToBool" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
